rules_version = '2';

// derlife-audit Storage 安全規則
// ⚠️ 這份規則是「整個 bucket 一份、整份覆蓋」。
// 廠商及客戶資料系統的「簽名版報價單」由後台管理員（已登入）上傳到
// contact-signed-quotations/，走下面的預設「需登入」規則即可，不需要公開寫入。
service firebase.storage {
  match /b/{bucket}/o {
    // 所有路徑：需登入才能讀寫（Firebase 預設安全規則）
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
